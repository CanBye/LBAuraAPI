# Discord Bot Token (Required)
BOT_TOKEN=your_discord_bot_token_here

# API Server
PORT=4001
API_HOST=0.0.0.0
API_BASE_URL=https://aura.lbdev.com.tr

# Webhook URL (Optional - sends presence updates to external services)
WEBHOOK_URL=

# Discord Webhook for stats (paste your Discord webhook URL here)
STATS_WEBHOOK_URL=

# Stats interval in ms (default 5 min = 300000)
STATS_INTERVAL_MS=300000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
